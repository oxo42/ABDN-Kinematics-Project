
theta1 = deg2rad(0); %[control:slider:090c]{"position":[18,19]}
theta2 = deg2rad(0); %[control:slider:0e33]{"position":[18,19]}
theta3 = deg2rad(0); %[control:slider:062c]{"position":[18,19]}
theta4 = deg2rad(0); %[control:slider:97cf]{"position":[18,19]}

a1 = dh_link_to_transformation_matrix(0, pi/2, 0, theta1);
a2 = dh_link_to_transformation_matrix(0, 0, 0.150, theta2-pi/4);
a3 = dh_link_to_transformation_matrix(0, 0, 0.150, theta3-pi/4);
a4 = dh_link_to_transformation_matrix(0, pi/2, 0, theta4); % d4 might be something
T = a1 * a2 * a3 * a4 %[output:4be9f313]
T02 = a1 * a2;
T03 = a1 * a2 * a3;
%[output:4de317c4]
%[text] Let's now plot the origin and the location of the end effector in a top down view (XY plane) and a front view (XZ plane)
plot(0, 0, "bo", MarkerFaceColor="b") %[output:3fe9f59b]
hold on %[output:3fe9f59b]
plot(T(1,4), T(2,4), "ro", MarkerFaceColor="r") %[output:3fe9f59b]
plot(T02(1,4), T02(2,4), "o") %[output:3fe9f59b]
plot(T03(1,4), T03(2,4), "o") %[output:3fe9f59b]

hold off %[output:3fe9f59b]
title("Top down view (XY) plane") %[output:3fe9f59b]
legend("origin", "end effector") %[output:3fe9f59b]
xlim([-0.5 0.5]) %[output:3fe9f59b]
ylim([-0.5 0.5]) %[output:3fe9f59b]
xlabel("X") %[output:3fe9f59b]
ylabel("Y") %[output:3fe9f59b]

% Plot the front view (XZ) plane
figure; %[output:2fd74274]
plot(0, 0, "bo", MarkerFaceColor="b") %[output:2fd74274]
hold on %[output:2fd74274]
plot(T(1,4), T(3,4), "ro", MarkerFaceColor="r") %[output:2fd74274]
plot(T02(1,4), T02(3,4), "o") %[output:2fd74274]
plot(T03(1,4), T03(3,4), "o") %[output:2fd74274]
hold off %[output:2fd74274]
title("Front view (XZ) plane") %[output:2fd74274]
legend("origin", "end effector") %[output:2fd74274]
xlim([-0.5 0.5]) %[output:2fd74274]
ylim([-0.5 0.5]) %[output:2fd74274]
xlabel("X") %[output:2fd74274]
ylabel("Z") %[output:2fd74274]

% Plot the front view (YZ) plane
figure; %[output:2e16241f]
plot(0, 0, "bo", MarkerFaceColor="b") %[output:2e16241f]
hold on %[output:2e16241f]
plot(T(2,4), T(3,4), "ro", MarkerFaceColor="r") %[output:2e16241f]
plot(T02(2,4), T02(3,4), "o") %[output:2e16241f]
plot(T03(2,4), T03(3,4), "o") %[output:2e16241f]
hold off %[output:2e16241f]
title("Side view (YZ) plane") %[output:2e16241f]
legend("origin", "end effector") %[output:2e16241f]
xlim([-0.5 0.5]) %[output:2e16241f]
ylim([-0.5 0.5]) %[output:2e16241f]
xlabel("Y") %[output:2e16241f]
ylabel("Z") %[output:2e16241f]

